{
  "schema_version": 1,
  "mode": "allowlist",
  "target_repo": "imweb-ai-toolkit",
  "target_history": "fresh",
  "include": [
    "README.md",
    "README.ko.md",
    "README.ja.md",
    "README.zh-CN.md",
    "LICENSE",
    "TRADEMARKS.md",
    "package.json",
    "plugin.json",
    ".mcp.json",
    ".codex-plugin/**",
    ".claude-plugin/**",
    ".cursor-plugin/**",
    "assets/**",
    "docs/cli-toolkit-integration.md",
    "docs/imweb-ai-toolkit.md",
    "docs/public-export-allowlist.json",
    "docs/skill-installation-and-usage.md",
    "docs/surface-support-matrix.md",
    "examples/**",
    "install/**",
    "skills/imweb/**"
  ],
  "exclude_by_omission": true,
  "notes": [
    "public snapshot은 include에 적힌 경로만 복사합니다.",
    "운영용 작성, 검증, 배포 준비 문서는 allowlist 밖에 둡니다.",
    "public snapshot은 fresh history 기준으로 만듭니다."
  ]
}
