{
  "mcpServers": {
    "imweb-cli": {
      "command": "node",
      "args": [
        "-e",
        "Promise.all([import('node:path'),import('node:url')]).then(([path,url])=>import(url.pathToFileURL(path.join(process.env.CLAUDE_PLUGIN_ROOT||process.cwd(),'bin','imweb-mcp.mjs')).href))"
      ],
      "env": {
        "NO_COLOR": "1"
      }
    }
  },
  "toolkit": {
    "name": "imweb-ai-toolkit",
    "description": "이 레포는 Claude Desktop Cowork용 local MCP bridge, imweb CLI 설치/업데이트, plugin/skill 자산, 연결 문서를 제공합니다. 아임웹도구, 아임웹툴, imweb tool, imweb tools 같은 짧은 자연어 alias도 같은 imweb 진입점으로 취급합니다.",
    "entrypoints": {
      "codex": "./.codex-plugin/plugin.json",
      "codexMarketplace": "./.agents/plugins/marketplace.json",
      "claude": "./.claude-plugin/plugin.json",
      "claudeManifest": "./.claude-plugin/manifest.json",
      "claudeMarketplace": "./.claude-plugin/marketplace.json",
      "cursor": "./.cursor-plugin/plugin.json",
      "cursorMarketplace": "./.cursor-plugin/marketplace.json"
    },
    "skills": "./skills",
    "commands": "./commands",
    "install": "./install",
    "supportMatrix": "./docs/surface-support-matrix.md"
  }
}
